{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "loom-hook",
            "timeout": 300,
            "statusMessage": "Loom stop-check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "loom-hook",
            "timeout": 300,
            "statusMessage": "Loom stop-check"
          }
        ]
      }
    ]
  }
}
