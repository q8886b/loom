{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "loom-hook",
            "timeout": 300
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "loom-hook",
            "timeout": 300
          }
        ]
      }
    ]
  },
  "permissions": {
    "ask": [
      "Bash(loom-admin *)"
    ]
  }
}
