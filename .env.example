# Loom environment configuration
# Copy this file to ~/.loom/.env and fill in your keys.

# Required for embedding / vector search (Zhipu Embedding-3)
# Uncomment and fill in your key:
# ZHIPU_API_KEY=your-zhipu-api-key

# Optional: override default Loom home directory
# LOOM_HOME=/path/to/custom/loom/home
